{
  "name": "golf-scramble-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server/scripts/local-dev.js",
    "dev:client": "vite",
    "dev:server": "node server/scripts/reset-session-logs.js && nodemon server/index.js",
    "start": "node server/scripts/reset-session-logs.js && node server/index.js",
    "prebuild": "node server/scripts/cleanup-logs.js",
    "build": "vite build && npm run db:migrate",
    "postinstall": "npm run build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "node --test test/app.test.js test/schema-rollback.test.js",
    "seed:homepage-demo": "node server/scripts/seed-homepage-demo.js",
    "db:rollback:chat": "node server/scripts/run-one-time-chat-schema-rollback.js",
    "db:migrate": "node server/run-migrations.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-auth": "^1.3.6",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "mysql2": "^3.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "nodemon": "^3.1.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
